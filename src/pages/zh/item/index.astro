---
import Base from '../../../layouts/Base.astro';
import { latestBrief, categoryLabel } from '../../../utils/data';
import { allDailyBriefs } from '../../../utils/dailyData';

const briefs = allDailyBriefs();
const payload = JSON.stringify({ latest: latestBrief, briefs });
---
<Base title="中文研究解读 · Latest AI News" description="AI 新闻中文研究解读页面">
  <article class="item-page" id="item-page">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/zh/">首页</a>
      <span>/</span>
      <a href="/archive/">归档</a>
      <span>/</span>
      <span id="crumb-date">中文研究解读</span>
    </nav>
    <header class="item-hero">
      <p class="eyebrow small">中文研究阅读版</p>
      <h1 id="item-title">正在读取中文研究页</h1>
      <p class="item-deck" id="item-deck">如果没有自动显示，请返回首页。</p>
      <div class="item-meta-grid" id="item-meta"></div>
      <div class="hero-actions" id="item-actions"><a class="button button-ghost" href="/zh/">返回首页</a></div>
    </header>
    <section class="digest-section conclusion-card"><p class="eyebrow small">一句话结论</p><p id="item-insight"></p></section>
    <section class="digest-section" id="item-points-wrap"><h2>核心要点</h2><div class="point-grid" id="item-points"></div></section>
    <section class="digest-section prose-card"><h2>背景说明</h2><p id="item-background"></p></section>
    <section class="digest-section prose-card"><h2>详细解读</h2><p id="item-summary"></p><p id="item-extra"></p></section>
    <section class="digest-section prose-card"><h2>影响判断</h2><p id="item-impact"></p></section>
    <section class="digest-section" id="item-evidence-wrap"><h2>证据与来源</h2><div class="evidence-list" id="item-evidence"></div></section>
  </article>
  <script type="application/json" id="item-payload" set:html={payload}></script>
  <script is:inline>
    const payloadEl = document.getElementById('item-payload');
    const payload = JSON.parse(payloadEl?.textContent || '{}');
    const path = window.location.pathname;
    const match = path.match(/\/zh\/items\/([^/]+)\/([^/]+)\/?/);
    const date = match?.[1] || payload.latest?.date || '';
    const slug = match?.[2] || '';
    const brief = (payload.briefs || []).find((b) => b.date === date) || payload.latest || (payload.briefs || [])[0];
    const fallbackSlug = (item) => (item?.slug || item?.duplicate_group_id || item?.title_original || item?.title || 'item').toString().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || 'item';
    const item = (brief?.items || []).find((x) => (x.slug || fallbackSlug(x)) === slug) || (brief?.items || [])[0];
    const setText = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value || ''; };
    const esc = (value) => String(value || '').replace(/[&<>"]/g, (s) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[s]));
    if (brief) setText('crumb-date', brief.date || date);
    if (item) {
      const title = item.title_zh || item.title || item.title_original || '中文研究解读';
      document.title = `${title} · 中文研究解读`;
      setText('item-title', title);
      setText('item-deck', item.summary_zh || item.insight_zh || item.summary_en || title);
      setText('item-insight', item.insight_zh || item.summary_zh || '');
      setText('item-background', item.background_zh || '');
      setText('item-summary', item.summary_zh || item.summary_en || '');
      setText('item-extra', item.extracted_text_for_analysis ? `${String(item.extracted_text_for_analysis).slice(0, 520)}……` : '');
      setText('item-impact', item.impact_zh || '');
      const meta = document.getElementById('item-meta');
      if (meta) {
        meta.innerHTML = `<div><span>来源</span><strong>${esc(item.source_name)}</strong></div><div><span>发布时间</span><strong>${esc(item.published_at)}</strong></div><div><span>抓取时间</span><strong>${esc(item.fetched_at)}</strong></div><div><span>分类</span><strong>${esc(item.category || '')}</strong></div>`;
      }
      const actions = document.getElementById('item-actions');
      if (actions) {
        actions.innerHTML = `${item.original_url ? `<a class="button button-primary" href="${esc(item.original_url)}" target="_blank" rel="noreferrer">查看原始来源 / Source</a>` : ''}<a class="button button-ghost" href="/zh/">返回首页</a>`;
      }
      const points = Array.isArray(item.key_points_zh) ? item.key_points_zh : [];
      const pointsEl = document.getElementById('item-points');
      if (pointsEl) pointsEl.innerHTML = points.slice(0, 6).map((p, i) => `<p><strong>${i + 1}</strong><span>${esc(p)}</span></p>`).join('');
      const evidence = Array.isArray(item.evidence_zh) ? item.evidence_zh : [];
      const evidenceEl = document.getElementById('item-evidence');
      if (evidenceEl) evidenceEl.innerHTML = evidence.map((e) => `<a href="${esc(e.source_url || item.original_url || '#')}" target="_blank" rel="noreferrer"><strong>${esc(e.label)}</strong><span>${esc(e.text)}</span></a>`).join('');
    } else {
      setText('item-title', '未找到对应中文研究页');
      setText('item-deck', '请返回首页或归档页查看最新内容。');
    }
  </script>
</Base>
