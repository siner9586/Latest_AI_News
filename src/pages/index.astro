---
import Base from '../layouts/Base.astro';
import { latestBrief, newsFocus } from '../utils/data';
const b = latestBrief;
---
<Base title={`AI 新闻简报 · ${b.date}`} description={b.overview_zh}>
  <section class="hero">
    <div class="eyebrow">AI Executive · Podcast · Media Radar</div>
    <h1>每日AI 核心动态。</h1>
    <p>{b.overview_zh}</p>
    <p class="muted">最新一期 · {b.date} · 候选 {b.candidate_count} · 入选 {b.selected_count} · 来源 {b.source_count}</p>
  </section>
  <section class="grid">
    <div class="card">
      <h2 class="section-title">今日重点</h2>
      {b.items.map((item:any) => (
        <article class="item">
          <p class="meta">{item.category} · {item.source_name} · {item.published_at}</p>
          <h3>{item.title}</h3>
          <p>{newsFocus(item, 'zh')}</p>
          <a class="pill" href={item.original_url} target="_blank" rel="noreferrer">原始来源</a>
          {(item.tags || []).map((t:string) => <span class="pill">#{t}</span>)}
        </article>
      ))}
    </div>
    <aside class="card">
      <h2 class="section-title">信息源统计</h2>
      <div class="stats">
        <div class="stat"><strong>{b.source_count}</strong><span>来源</span></div>
        <div class="stat"><strong>{b.candidate_count}</strong><span>候选</span></div>
        <div class="stat"><strong>{b.selected_count}</strong><span>入选</span></div>
      </div>
      <h2 class="section-title" style="margin-top:24px">分类</h2>
      {b.categories.map((c:string) => <span class="pill">{c}</span>)}
      <p class="notice">所有条目必须有原始链接；没有足够真实抓取内容时，只发布来源索引，不用测试新闻冒充更新。</p>
    </aside>
  </section>
</Base>
