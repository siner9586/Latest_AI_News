---
import Base from '../layouts/Base.astro';
import BriefDashboard from '../components/BriefDashboard.astro';
import { latestBrief } from '../utils/data';
const b = latestBrief;
---
<Base title={`AI 新闻简报 · ${b.date}`} description={b.overview_zh}>
  <BriefDashboard b={b} lang="zh" subtitle={b.overview_zh} />
</Base>
