---
import Base from '../../layouts/Base.astro';
import { latestBrief } from '../../utils/data';
const b = latestBrief;
---
<Base title={`English AI News Brief · ${b.date}`} description={b.overview_en}>
  <section class="hero">
    <div class="eyebrow">Daily AI Intelligence</div>
    <h1>Executive-grade AI news, every morning.</h1>
    <p>{b.overview_en}</p>
    <p class="muted">Latest · {b.date} · Candidates {b.candidate_count} · Selected {b.selected_count} · Sources {b.source_count}</p>
  </section>
  <section class="grid">
    <div class="card">
      <h2 class="section-title">Highlights</h2>
      {b.items.map((item:any) => (
        <article class="item">
          <p class="meta">{item.category} · {item.source_name}</p>
          <h3>{item.title}</h3>
          <p>{item.summary_en}</p>
          <a class="pill" href={item.original_url} target="_blank" rel="noreferrer">Original source</a>
          {(item.tags || []).map((t:string) => <span class="pill">#{t}</span>)}
        </article>
      ))}
    </div>
    <aside class="card">
      <h2 class="section-title">Coverage</h2>
      <div class="stats">
        <div class="stat"><strong>{b.source_count}</strong><span>sources</span></div>
        <div class="stat"><strong>{b.candidate_count}</strong><span>candidates</span></div>
        <div class="stat"><strong>{b.selected_count}</strong><span>selected</span></div>
      </div>
    </aside>
  </section>
</Base>
