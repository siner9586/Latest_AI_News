---
import Base from '../../../layouts/Base.astro';
import { latestBrief, archiveIndex } from '../../../utils/data';

export function getStaticPaths() {
  const dates = archiveIndex.items?.length ? archiveIndex.items : [{ date: latestBrief.date }];
  return dates.map((d:any) => ({ params: { date: d.date }, props: { b: latestBrief } }));
}
const { b } = Astro.props;
---
<Base title={`English AI News Brief · ${b.date}`} description={b.overview_en}>
  <section class="hero">
    <h1>English AI News Brief · {b.date}</h1>
    <p>{b.overview_en}</p>
  </section>
  <section class="card">
    {b.items.map((item:any) => (
      <article class="item">
        <p class="meta">{item.category} · {item.source_name}</p>
        <h3>{item.title}</h3>
        <p>{item.summary_en}</p>
        <a class="pill" href={item.original_url} target="_blank" rel="noreferrer">Original source</a>
      </article>
    ))}
  </section>
</Base>
