---
import Base from '../../layouts/Base.astro';
import { companyIndex } from '../../utils/data';
---
<Base title="Companies · Latest AI News">
  <section class="hero">
    <h1>Companies & Institutions</h1>
    <p>AI companies, labs, platforms, investor firms and media institutions.</p>
  </section>
  <section class="list">
    {companyIndex.map((c) => (
      <article class="source-card">
        <p class="meta">{c.type} · {c.importance}</p>
        <h3><a href={c.url} target="_blank" rel="noreferrer">{c.name}</a></h3>
        <p>{(c.tags || []).map((t) => <span class="pill">{t}</span>)}</p>
      </article>
    ))}
  </section>
</Base>
