---
import Base from '../../layouts/Base.astro';
import BriefDashboard from '../../components/BriefDashboard.astro';
import { dailyArchiveRows, dailyBriefByDate } from '../../utils/dailyData';

export function getStaticPaths() {
  return dailyArchiveRows().map((row: any) => {
    const date = String(row.date);
    return { params: { date }, props: { b: dailyBriefByDate(date) } };
  });
}
const { b } = Astro.props;
---
<Base title={`AI 新闻简报 · ${b.date}`} description={b.overview_zh}>
  <BriefDashboard
    b={b}
    lang="zh"
    eyebrow="Daily Archive Brief"
    title={`AI 新闻简报 · ${b.date}`}
    subtitle={b.overview_zh}
  />
</Base>
