---
import '../styles/global.css';
import '../styles/localized.css';
const { title = 'Latest AI News', description = 'Daily AI executive, podcast, media and product news brief.' } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070b16" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Latest AI News RSS" href="/rss.xml" />
  </head>
  <body>
    <a class="skip-link" href="#content">跳到正文</a>
    <div class="ambient-layer" aria-hidden="true"></div>
    <header class="nav">
      <div class="shell nav-inner">
        <a class="brand" href="/" aria-label="Latest AI News home">
          <span class="brand-mark">AI</span>
          <span class="brand-copy"><strong>Latest AI News</strong><small>Executive Briefing</small></span>
        </a>
        <nav class="nav-links" aria-label="Main navigation">
          <a href="/zh/">中文</a>
          <a href="/en/">English</a>
          <a href="/archive/">Archive</a>
          <a href="/sources/">Sources</a>
          <a href="/people/">People</a>
          <a href="/companies/">Companies</a>
          <a href="/tags/">Tags</a>
          <a href="/about/">About</a>
          <span class="wechat-nav">
            <a class="wechat-link" href="#wechat-popover" aria-controls="wechat-popover">公众号</a>
            <span id="wechat-popover" class="wechat-popover" role="dialog" aria-label="微信公众号二维码">
              <a class="wechat-close" href="#" aria-label="关闭公众号二维码">×</a>
              <img src="/wechat-qr.svg" alt="微信公众号二维码" loading="eager" decoding="sync" />
              <span class="wechat-caption">微信扫码关注公众号</span>
            </span>
          </span>
        </nav>
      </div>
    </header>
    <main id="content" class="shell"><slot /></main>
    <footer class="shell footer">
      <div>
        <strong>Latest AI News</strong>
        <span>Daily at 07:12 Beijing/Taipei time · Source-linked Chinese research digests.</span>
      </div>
      <div>Original links · Chinese reading pages · production data only.</div>
    </footer>
  </body>
</html>
